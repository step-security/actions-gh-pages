{
  "name": "actions-github-pages",
  "version": "4.0.0",
  "description": "GitHub Actions for GitHub Pages",
  "main": "lib/index.js",
  "engines": {
    "node": ">=v20.11.0",
    "npm": ">=10.2.4"
  },
  "scripts": {
    "all": "npm run format && npm run lint && npm test && npm run build",
    "lint": "eslint ./{src,__tests__}/**/*.ts",
    "lint:fix": "eslint --fix ./{src,__tests__}/**/*.ts",
    "test": "jest --coverage --verbose --detectOpenHandles",
    "build": "npm run tsc && ncc build ./src/index.ts -o dist --minify --external @actions/github",
    "tsc": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/actions-gh-pages.git"
  },
  "keywords": [
    "GitHub Actions",
    "Actions",
    "JavaScript Action",
    "TypeScript Action",
    "GitHub Pages",
    "gh-pages"
  ],
  "author": "step-security",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/step-security/actions-gh-pages/issues"
  },
  "homepage": "https://github.com/step-security/actions-gh-pages#readme",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^9.0.0",
    "@actions/glob": "^0.5.0",
    "@actions/io": "^1.1.2",
    "@types/shelljs": "^0.8.11",
    "axios": "^1.7.10",
    "shelljs": "^0.8.5"
  },
  "devDependencies": {
    "@types/jest": "^29.2.6",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "~16",
    "@typescript-eslint/eslint-plugin": "^5.48.2",
    "@typescript-eslint/parser": "^5.48.2",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^8.32.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.3.1",
    "jest-circus": "^29.3.1",
    "js-yaml": "^4.1.0",
    "prettier": "2.8.8",
    "ts-jest": "^29.0.5",
    "typescript": "^4.9.4"
  }
}
